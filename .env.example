# Discord application
DISCORD_TOKEN=your_bot_token
DISCORD_CLIENT_ID=your_application_id

# Optional: deploy slash commands instantly to one development server.
# Remove this value before deploying commands globally.
DISCORD_GUILD_ID=your_test_server_id

# Comma-separated Discord user IDs allowed to use developer commands.
DEVELOPER_IDS=your_user_id,another_developer_id

# MongoDB Atlas or self-hosted MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=xavion
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=2
# Comma-separated DNS resolvers used for mongodb+srv records.
MONGODB_DNS_SERVERS=8.8.8.8,9.9.9.9

# Bot behavior
PREFIX=X
BOT_ACTIVITY_TEXT=Listening to X
BOT_ACTIVITY_TYPE=custom
BOT_STATUS=dnd
EMBED_COLOR=#ccad00

# Mention greeting buttons
SUPPORT_SERVER_URL=https://discord.gg/your-server
# Optional. Leave empty to generate an invite from DISCORD_CLIENT_ID.
BOT_INVITE_URL=

# Runtime
NODE_ENV=production
LOG_LEVEL=info
